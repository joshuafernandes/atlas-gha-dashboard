# 
# Boiler plate
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Restrict login to users whose email ends with this domain.
ALLOWED_EMAIL_DOMAIN=myOrg.net
#
# Authn - Google 
# Setup:  https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://your-domain/api/auth/callback/google     (prod)
# -----------------------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# Authn - Github
# -----------------------------------------------------------------------------------------------
# Option A: GitHub App (recommended — works across multiple orgs)
# Required permissions: Metadata (read), Pull requests (read), Actions (read),
#   Checks (read), Secrets (read), Code scanning alerts (read — optional)
GITHUB_APP_ID=123456
# Remember the private key needs to be in pkcs8 fromat
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEo...
-----END RSA PRIVATE KEY-----"
# Optional: pin to a specific installation ID (skips auto-discovery)
# GITHUB_APP_INSTALLATION_ID=
#
# Option B: Personal access token (fallback — used when app vars above are absent)
# Classic PAT scopes: repo, security_events (optional, for code scanning)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
#
# -----------------------------------------------------------------------------------------------
#
# Github Repo Config 
# Repos to monitor (comma-separated owner/repo pairs)
GITHUB_REPOS=myOrgA/repo1,myOrgA/repo2,myOrgB/repo3
# Number of workflow runs to fetch per workflow for analytics.
# Higher values give more sparkline history but cost more API calls.
# Default: 20  |  Max: 100
WORKFLOW_RUNS_LIMIT=20

